/* 一绳一愿 · 全局高级藏式视觉 */
page {
  --bg: #efe6d8;
  --bg-soft: #f8f0e5;
  --card: #fffaf2;
  --ink: #24130d;
  --muted: #8a7664;
  --dim: #b8a58f;
  --red: #7d1717;
  --red-deep: #3b1210;
  --gold: #c9a050;
  --gold-light: #ead08a;
  --line: rgba(125,23,23,0.12);
  --shadow: 0 18rpx 48rpx rgba(58,25,12,0.12);
  background: var(--bg);
  color: var(--ink);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Noto Sans SC', 'STSong', serif;
  font-size: 28rpx;
}

.container { min-height: 100vh; background: var(--bg); }
.text-gold { color: var(--gold); }
.text-red { color: var(--red); }
.text-muted { color: var(--muted); }

.btn-gold {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  background: linear-gradient(135deg, #8f641d, #c9a050 48%, #e6c76d);
  color: #fff;
  border: none;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
  box-shadow: 0 18rpx 34rpx rgba(125,23,23,0.18);
}

.btn-outline {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 92rpx;
  background: rgba(255,250,242,0.78);
  color: var(--red);
  border: 1rpx solid rgba(125,23,23,0.25);
  border-radius: 999rpx;
  font-size: 28rpx;
  letter-spacing: 4rpx;
}

.divider {
  width: 120rpx;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, var(--gold), transparent);
  margin: 24rpx auto;
}

/* 统一抽屉 */
.drawer-mask {
  position: fixed;
  inset: 0;
  background: rgba(18,9,5,0.52);
  backdrop-filter: blur(8rpx);
  z-index: 100;
  opacity: 0;
  visibility: hidden;
  transition: all .25s;
}
.drawer-mask.show { opacity: 1; visibility: visible; }
.drawer {
  position: fixed;
  top: 0; right: 0;
  width: 590rpx;
  height: 100%;
  background: linear-gradient(180deg,#fffaf2,#f4e7d5);
  z-index: 101;
  transform: translateX(100%);
  transition: transform .32s cubic-bezier(.2,.8,.2,1);
  display: flex;
  flex-direction: column;
  box-shadow: -24rpx 0 60rpx rgba(0,0,0,.22);
}
.drawer.show { transform: translateX(0); }
.drawer-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 54rpx 34rpx 24rpx;
  border-bottom: 1rpx solid rgba(125,23,23,0.1);
}
.drawer-title { font-size: 34rpx; font-weight: 700; color: var(--ink); letter-spacing: 4rpx; }
.drawer-close { font-size: 32rpx; color: var(--muted); padding: 10rpx; }
.drawer-body { flex: 1; overflow-y: auto; padding: 30rpx 34rpx; }
.drawer-group { margin-bottom: 42rpx; }
.drawer-label {
  display: block;
  font-size: 24rpx;
  color: var(--red);
  font-weight: 700;
  margin-bottom: 18rpx;
  letter-spacing: 3rpx;
}
.drawer-tags { display: flex; flex-wrap: wrap; gap: 16rpx; }
.drawer-tag {
  padding: 16rpx 26rpx;
  font-size: 24rpx;
  color: var(--muted);
  background: rgba(255,255,255,0.72);
  border: 1rpx solid rgba(125,23,23,0.08);
  border-radius: 999rpx;
}
.drawer-tag.active {
  color: #fff;
  background: linear-gradient(135deg, var(--red), #a22c22);
  border-color: transparent;
  box-shadow: 0 10rpx 22rpx rgba(125,23,23,0.18);
}
.drawer-footer { display: flex; padding: 22rpx 34rpx 46rpx; gap: 18rpx; border-top: 1rpx solid rgba(125,23,23,0.1); }
.drawer-btn { flex: 1; padding: 24rpx 0; text-align: center; font-size: 28rpx; border-radius: 999rpx; }
.drawer-btn-reset { color: var(--muted); background: rgba(255,255,255,0.72); }
.drawer-btn-confirm { color: #fff; background: var(--red); font-weight: 600; }
