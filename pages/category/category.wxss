/* 分类页 · 新版高级商品流 */
.cat {
  min-height: 100vh;
  background: linear-gradient(180deg, #2a100d 0%, #7d1717 220rpx, #efe6d8 520rpx, #efe6d8 100%);
  padding-bottom: env(safe-area-inset-bottom);
}

.cat-nav { display: flex; align-items: center; justify-content: space-between; height: 108rpx; padding: 34rpx 32rpx 10rpx; color: #fff7e8; }
.cat-nav-left,.cat-nav-right { width: 110rpx; display: flex; align-items: center; }
.cat-nav-left { justify-content: flex-start; }
.cat-nav-right { justify-content: flex-end; }
.cat-nav-back { font-size: 56rpx; font-weight: 200; line-height: 1; color: rgba(255,247,232,.86); }
.cat-nav-title { font-size: 34rpx; font-weight: 600; letter-spacing: 14rpx; text-indent: 14rpx; }
.cat-nav-filter { padding: 12rpx 24rpx; border: 1rpx solid rgba(234,208,138,.42); border-radius: 999rpx; font-size: 23rpx; color: #f8e5b1; }

.cat-switch { display: flex; padding: 22rpx 32rpx 28rpx; gap: 18rpx; }
.cat-switch-item { padding: 16rpx 34rpx; font-size: 25rpx; color: rgba(255,247,232,.72); border-radius: 999rpx; background: rgba(255,255,255,.08); border: 1rpx solid rgba(255,255,255,.12); }
.cat-switch-item.on { color: #5b160f; background: linear-gradient(135deg,#f1d995,#c9a050); font-weight: 700; box-shadow: 0 14rpx 28rpx rgba(0,0,0,.18); }

.cat-hero { position: relative; margin: 0 32rpx 30rpx; height: 460rpx; border-radius: 34rpx; overflow: hidden; box-shadow: 0 24rpx 58rpx rgba(49,16,9,.24); border: 1rpx solid rgba(234,208,138,.22); }
.cat-hero-bg { width: 100%; height: 100%; }
.cat-hero-mask { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(0,0,0,.03), rgba(43,12,7,.12) 35%, rgba(43,12,7,.88)); }
.cat-hero-cap { position: absolute; left: 0; right: 0; bottom: 0; padding: 48rpx 34rpx 34rpx; }
.cat-hero-badge { display: inline-block; padding: 8rpx 18rpx; font-size: 21rpx; color: #4b120c; background: linear-gradient(135deg,#f1d995,#c9a050); border-radius: 999rpx; margin-bottom: 16rpx; font-weight: 600; }
.cat-hero-name { display: block; font-size: 38rpx; font-weight: 700; color: #fff8ea; margin-bottom: 12rpx; letter-spacing: 2rpx; text-shadow: 0 4rpx 20rpx rgba(0,0,0,.45); }
.cat-hero-row { display: flex; align-items: center; gap: 18rpx; }
.cat-hero-price { font-size: 44rpx; font-weight: 800; color: #f1d995; }
.cat-hero-deity { font-size: 24rpx; color: rgba(255,248,234,.72); }

.cat-head { display: flex; align-items: center; padding: 16rpx 34rpx 24rpx; gap: 18rpx; }
.cat-head-text { font-size: 23rpx; color: #8f735e; letter-spacing: 6rpx; flex-shrink: 0; }
.cat-head-line { flex: 1; height: 1rpx; background: linear-gradient(90deg, rgba(125,23,23,.18), transparent); }

.cat-grid { display: flex; flex-wrap: wrap; padding: 0 26rpx; justify-content: space-between; }
.cat-card { width: 340rpx; margin-bottom: 26rpx; background: #fffaf2; border-radius: 26rpx; overflow: hidden; box-shadow: 0 14rpx 34rpx rgba(58,25,12,.1); border: 1rpx solid rgba(125,23,23,.06); }
.cat-card-pic { position: relative; width: 340rpx; height: 370rpx; overflow: hidden; background: #e6d5c2; }
.cat-card-img { width: 340rpx; height: 370rpx; }
.cat-card-tag { position: absolute; top: 14rpx; left: 14rpx; padding: 7rpx 16rpx; font-size: 20rpx; color: #fff7e8; background: rgba(125,23,23,.82); border-radius: 999rpx; letter-spacing: 1rpx; }
.cat-card-body { padding: 20rpx 20rpx 22rpx; }
.cat-card-title { display: block; font-size: 27rpx; font-weight: 600; color: #24130d; margin-bottom: 12rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.cat-card-foot { display: flex; justify-content: space-between; align-items: center; }
.cat-card-amount { font-size: 32rpx; color: #7d1717; font-weight: 800; }
.cat-card-deity { font-size: 22rpx; color: #a28c74; max-width: 130rpx; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }

.cat-empty { padding: 120rpx 40rpx; text-align: center; display: flex; flex-direction: column; align-items: center; gap: 18rpx; }
.cat-empty-icon { font-size: 72rpx; }
.cat-empty-text { font-size: 26rpx; color: #8a7664; }
