/* 详情页 · 高级商品详情 */
.detail-img { width: 100%; display: block; background: #e6d5c2; }

.detail-info {
  position: relative;
  margin: -42rpx 24rpx 24rpx;
  padding: 34rpx 30rpx 32rpx;
  background: #fffaf2;
  border-radius: 34rpx;
  box-shadow: 0 18rpx 46rpx rgba(58,25,12,.12);
  border: 1rpx solid rgba(125,23,23,.06);
}
.detail-badge { display: inline-flex; padding: 8rpx 20rpx; border-radius: 999rpx; background: linear-gradient(135deg,#7d1717,#a12a22); margin-bottom: 18rpx; }
.detail-badge text { font-size: 21rpx; color: #fff7e8; letter-spacing: 2rpx; }
.detail-name { font-size: 42rpx; font-weight: 800; color: #24130d; display: block; margin-bottom: 14rpx; letter-spacing: 2rpx; line-height: 1.25; }
.detail-price { font-size: 52rpx; font-weight: 900; color: #7d1717; display: block; margin-bottom: 34rpx; }
.detail-specs { display: flex; flex-wrap: wrap; gap: 18rpx; padding: 26rpx 0; border-top: 1rpx solid rgba(125,23,23,.09); border-bottom: 1rpx solid rgba(125,23,23,.09); }
.spec-item { width: calc(50% - 9rpx); display: flex; flex-direction: column; gap: 8rpx; }
.spec-label { font-size: 21rpx; color: #a28c74; }
.spec-value { font-size: 26rpx; color: #24130d; line-height: 1.45; }
.detail-zodiac { padding: 24rpx 0 0; display: flex; align-items: center; gap: 12rpx; }
.zodiac-label { font-size: 22rpx; color: #a28c74; }
.zodiac-value { font-size: 25rpx; color: #7d1717; font-weight: 600; }

.detail-section { margin: 24rpx; padding: 34rpx 28rpx; background: #fffaf2; border-radius: 30rpx; box-shadow: 0 12rpx 30rpx rgba(58,25,12,.07); }
.section-header { display: flex; align-items: center; gap: 18rpx; margin-bottom: 22rpx; }
.section-line { flex: 1; height: 1rpx; background: linear-gradient(90deg, transparent, rgba(125,23,23,.22), transparent); }
.section-title { font-size: 25rpx; color: #7d1717; font-weight: 700; letter-spacing: 4rpx; flex-shrink: 0; }
.section-subtitle { font-size: 31rpx; color: #24130d; font-weight: 800; display: block; margin-bottom: 16rpx; }
.section-body { font-size: 27rpx; color: #6f5a49; line-height: 1.9; display: block; margin-bottom: 20rpx; }
.culture-box { padding: 22rpx 24rpx; background: rgba(125,23,23,.05); border-left: 5rpx solid #7d1717; border-radius: 14rpx; margin-bottom: 18rpx; }
.culture-box text { font-size: 25rpx; color: #6f5a49; line-height: 1.85; }
.section-note { font-size: 23rpx; color: #7d1717; display: block; }

.related-grid { display: flex; gap: 18rpx; overflow-x: auto; padding-bottom: 4rpx; }
.related-item { width: 190rpx; flex-shrink: 0; }
.related-img { width: 190rpx; height: 210rpx; border-radius: 22rpx; background: #e6d5c2; }
.related-name { font-size: 23rpx; color: #6f5a49; display: block; margin-top: 12rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.related-price { font-size: 27rpx; color: #7d1717; font-weight: 800; display: block; margin-top: 4rpx; }
.detail-cta-wrap { padding: 28rpx 24rpx 44rpx; text-align: center; }
.detail-cta { width: 100%; }
.cta-hint { display: block; font-size: 22rpx; color: #a28c74; margin-top: 16rpx; letter-spacing: 2rpx; }
