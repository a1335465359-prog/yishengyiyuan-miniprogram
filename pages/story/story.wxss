/* 故事页 · 文化杂志感 */
.story { min-height: 100vh; background: #efe6d8; }
.story-hero { position: relative; width: 100%; height: 430rpx; overflow: hidden; background: #28100b; }
.story-hero-bg { width: 100%; height: 100%; }
.story-hero-mask { position: absolute; inset: 0; background: radial-gradient(circle at 40% 30%, rgba(234,208,138,.2), transparent 36%), linear-gradient(180deg, rgba(24,8,5,.18), rgba(24,8,5,.86)); }
.story-hero-cap { position: absolute; left: 34rpx; right: 34rpx; bottom: 44rpx; }
.story-hero-title { display: block; font-size: 46rpx; font-weight: 800; color: #fff7e8; letter-spacing: 12rpx; text-indent: 12rpx; margin-bottom: 14rpx; text-shadow: 0 6rpx 20rpx rgba(0,0,0,.42); }
.story-hero-sub { display: block; font-size: 24rpx; color: rgba(255,247,232,.72); line-height: 1.6; letter-spacing: 2rpx; }
.story-list { padding: 28rpx 24rpx 0; }
.story-item { display: flex; align-items: flex-start; gap: 24rpx; padding: 28rpx; margin-bottom: 20rpx; background: #fffaf2; border-radius: 28rpx; box-shadow: 0 12rpx 34rpx rgba(58,25,12,.08); border: 1rpx solid rgba(125,23,23,.06); }
.story-item-avatar { width: 92rpx; height: 92rpx; border-radius: 28rpx; background: linear-gradient(135deg,#7d1717,#b44a2a); display: flex; align-items: center; justify-content: center; flex-shrink: 0; box-shadow: 0 12rpx 22rpx rgba(125,23,23,.18); }
.story-item-initial { font-size: 40rpx; font-weight: 800; color: #f7dc91; }
.story-item-main { flex: 1; min-width: 0; }
.story-item-head { display: flex; align-items: center; flex-wrap: wrap; gap: 12rpx; margin-bottom: 12rpx; }
.story-item-name { font-size: 31rpx; font-weight: 800; color: #24130d; }
.story-item-badge { padding: 5rpx 14rpx; font-size: 20rpx; color: #7d1717; background: rgba(125,23,23,.06); border-radius: 999rpx; }
.story-item-desc { font-size: 25rpx; color: #6f5a49; line-height: 1.75; margin-bottom: 14rpx; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
.story-item-foot { display: flex; justify-content: space-between; align-items: center; }
.story-item-bless { font-size: 22rpx; color: #b58a2b; letter-spacing: 1rpx; }
.story-item-arrow { font-size: 34rpx; color: #b8a58f; font-weight: 200; }
.story-foot { display: flex; align-items: center; justify-content: center; gap: 20rpx; padding: 44rpx 40rpx 70rpx; }
.story-foot-line { flex: 1; max-width: 80rpx; height: 1rpx; background: linear-gradient(90deg, transparent, rgba(125,23,23,.22), transparent); }
.story-foot-text { font-size: 23rpx; color: #9b8068; letter-spacing: 2rpx; white-space: nowrap; }
