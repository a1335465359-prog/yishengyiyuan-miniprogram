/* 首页 · 高级藏红首屏 */
.home {
  position: relative;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  background: #1c0d09;
}

.home-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
  transform: scale(1.02);
}

.home-shade {
  position: absolute;
  inset: 0;
  z-index: 2;
  background:
    radial-gradient(circle at 50% 32%, rgba(236,197,109,.22), transparent 34%),
    linear-gradient(180deg, rgba(24,8,5,.78) 0%, rgba(24,8,5,.28) 36%, rgba(24,8,5,.58) 70%, rgba(24,8,5,.92) 100%);
}

.home-shade::after {
  content: '';
  position: absolute;
  inset: 28rpx;
  border: 1rpx solid rgba(234,208,138,.22);
  border-radius: 34rpx;
  pointer-events: none;
}

.home-top {
  position: absolute;
  top: 12vh;
  left: 0; right: 0;
  z-index: 3;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.home-en {
  font-size: 18rpx;
  color: rgba(234,208,138,.62);
  letter-spacing: 10rpx;
  margin-bottom: 26rpx;
}

.home-name {
  font-size: 66rpx;
  font-weight: 300;
  color: #fff6e9;
  letter-spacing: 28rpx;
  text-indent: 28rpx;
  text-shadow: 0 10rpx 34rpx rgba(0,0,0,.5);
}

.home-divider { display: flex; align-items: center; gap: 14rpx; margin: 30rpx 0 22rpx; }
.home-dot { width: 8rpx; height: 8rpx; background: #d6af54; border-radius: 50%; box-shadow: 0 0 18rpx rgba(214,175,84,.8); }
.home-dot:nth-child(2) { width: 14rpx; height: 14rpx; }
.home-tag { font-size: 24rpx; color: rgba(255,246,233,.7); letter-spacing: 8rpx; }

.home-entries {
  position: absolute;
  top: 55vh;
  left: 0; right: 0;
  z-index: 3;
  display: flex;
  padding: 0 44rpx;
  gap: 24rpx;
}

.home-entry {
  flex: 1;
  height: 270rpx;
  border-radius: 28rpx;
  overflow: hidden;
  position: relative;
  box-shadow: 0 22rpx 54rpx rgba(0,0,0,.42);
  border: 1rpx solid rgba(234,208,138,.28);
}
.home-entry:active { transform: scale(.98); }
.home-entry-bg { position: absolute; inset: 0; width: 100%; height: 100%; z-index: 1; }
.home-entry-veil { position: absolute; inset: 0; z-index: 2; background: linear-gradient(180deg, rgba(0,0,0,.04), rgba(0,0,0,.18) 40%, rgba(36,12,8,.8)); }
.home-entry-cap { position: absolute; left: 0; right: 0; bottom: 0; z-index: 3; padding: 0 18rpx 26rpx; text-align: center; }
.home-entry-zh { display: block; font-size: 38rpx; font-weight: 500; color: #fff7e8; letter-spacing: 12rpx; text-indent: 12rpx; margin-bottom: 6rpx; }
.home-entry-en { font-size: 18rpx; color: rgba(234,208,138,.78); letter-spacing: 5rpx; }

.home-foot {
  position: absolute;
  left: 56rpx; right: 56rpx; bottom: calc(7vh + env(safe-area-inset-bottom));
  z-index: 3;
  height: 86rpx;
  border-radius: 999rpx;
  background: rgba(255,246,233,.12);
  border: 1rpx solid rgba(234,208,138,.28);
  display: flex; align-items: center; justify-content: center; gap: 20rpx;
  backdrop-filter: blur(10rpx);
}
.home-foot-line { width: 70rpx; height: 1rpx; background: linear-gradient(90deg, transparent, rgba(234,208,138,.8), transparent); }
.home-foot-text { font-size: 25rpx; color: #fff6e9; letter-spacing: 5rpx; }
