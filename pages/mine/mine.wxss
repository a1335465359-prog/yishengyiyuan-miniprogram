/* 我的页面 · 与新版统一 */
.mine {
  min-height: 100vh;
  background: linear-gradient(180deg, #2a100d 0%, #7d1717 210rpx, #efe6d8 430rpx, #efe6d8 100%);
  padding-top: 86rpx;
}
.mine-header { display: flex; flex-direction: column; align-items: center; padding-bottom: 44rpx; color: #fff7e8; }
.mine-avatar { width: 132rpx; height: 132rpx; border-radius: 38rpx; background: linear-gradient(135deg,#f1d995,#c9a050); display: flex; align-items: center; justify-content: center; margin-bottom: 24rpx; box-shadow: 0 18rpx 36rpx rgba(0,0,0,.22); }
.mine-avatar-text { font-size: 46rpx; color: #5b160f; font-weight: 900; }
.mine-name { font-size: 36rpx; font-weight: 800; letter-spacing: 8rpx; margin-bottom: 10rpx; text-shadow: 0 6rpx 20rpx rgba(0,0,0,.25); }
.mine-desc { font-size: 23rpx; color: rgba(255,247,232,.72); letter-spacing: 2rpx; }
.mine-menu { margin: 0 24rpx; background: #fffaf2; border-radius: 30rpx; overflow: hidden; box-shadow: 0 18rpx 44rpx rgba(58,25,12,.12); border: 1rpx solid rgba(125,23,23,.06); }
.mine-btn { display: flex; align-items: center; gap: 22rpx; padding: 34rpx 30rpx; background: transparent; border: none; border-radius: 0; text-align: left; font-size: inherit; line-height: inherit; color: inherit; }
.mine-btn::after { border: none; }
.mine-btn:not(:last-child) { border-bottom: 1rpx solid rgba(125,23,23,.08); }
.mine-btn-icon { width: 58rpx; height: 58rpx; border-radius: 18rpx; display: flex; align-items: center; justify-content: center; font-size: 24rpx; color: #fff; flex-shrink: 0; }
.mine-btn-icon-service { background: linear-gradient(135deg,#7d1717,#a12a22); }
.mine-btn-icon-about { background: linear-gradient(135deg,#9a6d24,#c9a050); }
.mine-btn-icon-share { background: linear-gradient(135deg,#332019,#73523d); }
.mine-btn-text { flex: 1; font-size: 28rpx; color: #24130d; letter-spacing: 2rpx; font-weight: 600; }
.mine-btn-arrow { font-size: 30rpx; color: #b8a58f; font-weight: 200; }
.mine-quote { text-align: center; padding: 60rpx 40rpx 26rpx; }
.mine-quote-text { display: block; font-size: 28rpx; color: #24130d; font-weight: 700; letter-spacing: 4rpx; margin-bottom: 10rpx; }
.mine-quote-sub { display: block; font-size: 23rpx; color: #9b8068; letter-spacing: 2rpx; }
.mine-version { display: block; text-align: center; font-size: 20rpx; color: #b8a58f; padding: 20rpx 0 46rpx; }
